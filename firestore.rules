rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    // Returns true if the user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the current user owns the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the current user has admin privileges
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.admin == true;
    }


    // Users
    // Read rules:
    // - Only authenticated users can read user profiles.
    // Write rules:
    // - Users can only create their own profile.
    // - Users can only update or delete their own profile.

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }


    // Platform settings
    // Read rules:
    // - Anyone can read shared platform settings (for example categories).
    // Write rules:
    // - Only admins can change platform settings.

    match /platform/settings {
      allow read: if true;
      allow write: if isAdmin();
    }


    // Workshops
    // Read rules:
    // - All users (including guests) can read workshops that are approved.
    // - Workshop owners can read their own workshops.
    // - Admins can read all workshops (approved or not).
    // Write rules:
    // - Only the workshop owner can create, update, or delete their workshop.
    // - The ownerId field cannot be changed after creation.

    match /workshops/{workshopId} {

      allow read: if resource.data.status == "approved"
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }


    // Bookings
    // Read rules:
    // - Users can only read their own bookings.
    // Write rules:
    // - Users can only create bookings for themselves.
    // - Users can only update or delete their own bookings.
    // - The userId field cannot be changed after creation.

    match /bookings/{bookingId} {

      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }


    // Reviews
    // Read rules:
    // - Anyone can read reviews.
    // Write rules:
    // - Only authenticated users can create reviews for themselves.
    // - Users can only update or delete their own reviews.
    // - The userId field cannot be changed after creation.

    match /reviews/{reviewId} {

      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }


    // Translator reviews
    // Read rules:
    // - Anyone can read translator reviews.
    // Write rules:
    // - Only authenticated users can create translator reviews for themselves.
    // - Users can only update or delete their own translator reviews.
    // - The userId field cannot be changed after creation.

    match /translatorReviews/{reviewId} {

      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

  }
}